{
  "entities": {
    "Vehicle": {
      "title": "Vehicle",
      "description": "A specific rental vehicle (motorbike or car)",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["motorbike", "car"] },
        "model_name": { "type": "string" },
        "plate_number": { "type": "string" },
        "daily_rate": { "type": "number" },
        "status": { "type": "string", "enum": ["available", "maintenance", "retired"] },
        "images": { "type": "array", "items": { "type": "string" } },
        "features": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["type", "model_name", "plate_number", "daily_rate"]
    },
    "Reservation": {
      "title": "Reservation",
      "description": "A rental reservation record",
      "type": "object",
      "properties": {
        "vehicle_id": { "type": "string" },
        "start_date": { "type": "string", "format": "date-time" },
        "end_date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "totalPrice": { "type": "number" }
      },
      "required": ["vehicle_id", "start_date", "end_date", "status", "userId"]
    }
  },
  "firestore": {
    "vehicles": {
      "schema": "Vehicle",
      "description": "The active fleet of individual vehicles (by plate number)"
    },
    "reservations": {
      "schema": "Reservation",
      "description": "Customer reservations to prevent double-booking"
    }
  }
}
